#include <stdio.h>
#include <stdbool.h>
#include <time.h> 

#define FILAS 20
#define COLUMNAS 10

int tablero[FILAS][COLUMNAS] = {0};
long nodosVisitados = 0; 

typedef struct {
    int ancho;
    int alto;
    char nombre[10];
} Pieza;

bool esMovimientoValido(int fila, int col, Pieza p) {
    if (col + p.ancho > COLUMNAS || fila + p.alto > FILAS || col < 0) return false;
    return true; 
}

void buscarMejorPosicionDFS(int fila, int col, Pieza p, int* maxFila) {
    nodosVisitados++; 

    if (!esMovimientoValido(fila + 1, col, p)) {
        if (fila > *maxFila) {
            *maxFila = fila; 
        }
        return;
    }

    buscarMejorPosicionDFS(fila + 1, col, p, maxFila);
}

void ejecutarSimulacionLogistica() {
    Pieza piezas[] = {
        {2, 1, "Bloque L"}, 
        {1, 4, "Pieza I"}, 
        {2, 2, "Cubo O"}, 
        {3, 1, "Pieza T"}
    };
    int totalPiezas = 4;

    printf("============================================================\n");
    printf("   INFORME DE RENDIMIENTO IA: OPTIMIZACION LOGISTICA\n");
    printf("============================================================\n");
    printf("| Pieza        | Nodos (V) | Tiempo (ms) | Profundidad |\n");
    printf("|--------------|-----------|-------------|-------------|\n");

    for (int i = 0; i < totalPiezas; i++) {
        nodosVisitados = 0;
        int mejorFilaGlobal = -1;
        
        clock_t inicio = clock(); 

        for (int c = 0; c < COLUMNAS; c++) {
            if (c == 9 && piezas[i].ancho != 1) continue; 

            int maxFilaEnColumna = 0;
            buscarMejorPosicionDFS(0, c, piezas[i], &maxFilaEnColumna);
            
            if (maxFilaEnColumna > mejorFilaGlobal) {
                mejorFilaGlobal = maxFilaEnColumna;
            }
        }

        clock_t fin = clock();
        double tiempo_ms = ((double)(fin - inicio) / CLOCKS_PER_SEC) * 1000.0;

        printf("| %-12s | %9ld | %11.4f | %11d |\n", 
               piezas[i].nombre, nodosVisitados, tiempo_ms, mejorFilaGlobal);
    }
    printf("============================================================\n");
}

int main() {
    ejecutarSimulacionLogistica();
    return 0;
}
